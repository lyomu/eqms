# Copy to .env and adjust for local development. DO NOT commit a real .env.
# docker-compose reads these; application-local.yml references the same values.

# --- PostgreSQL (DDL owner / superuser for local dev) ---
POSTGRES_USER=eqms_owner
POSTGRES_PASSWORD=owner_dev_pw
POSTGRES_DB=eqms

# --- Least-privilege runtime application role (created by init script + granted by Liquibase) ---
EQMS_APP_PASSWORD=app_dev_pw

# --- MinIO (S3-compatible object storage; used from a later milestone) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Electronic-signature HMAC key (compliance rule 4). Override per environment. ---
# Dev-only placeholder; production must inject a strong secret via the deployment platform.
EQMS_SIGNATURE_HMAC_KEY=dev-only-change-me
EQMS_SIGNATURE_HMAC_KEY_ID=dev-1
