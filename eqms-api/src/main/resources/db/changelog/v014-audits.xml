<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Audit Management module (Milestone 12). Quality audits — distinct from the audit_logs trail.
         4 tables + AUDIT_MANAGE / AUDIT_APPROVE permissions. -->

    <changeSet id="v014-001-audits" author="eqms">
        <createTable tableName="audits">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_audits" nullable="false"/>
            </column>
            <column name="audit_no" type="VARCHAR(40)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_audits_no"/>
            </column>
            <column name="audit_title" type="VARCHAR(400)"><constraints nullable="false"/></column>
            <column name="audit_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="audit_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="auditor_id" type="BIGINT"/>
            <column name="auditee_id" type="BIGINT"/>
            <column name="scope" type="TEXT"/>
            <column name="status" type="VARCHAR(40)"><constraints nullable="false"/></column>
            <column name="submitted_by" type="BIGINT"/>
            <column name="completed_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="version" type="INT" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_by" type="BIGINT"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <createIndex tableName="audits" indexName="ix_audits_status"><column name="status"/></createIndex>
        <createIndex tableName="audits" indexName="ix_audits_type"><column name="audit_type"/></createIndex>
    </changeSet>

    <changeSet id="v014-002-audit-findings" author="eqms">
        <createTable tableName="audit_findings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_audit_findings" nullable="false"/>
            </column>
            <column name="audit_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_af_audit" references="audits(id)"/>
            </column>
            <column name="finding_number" type="INT"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"><constraints nullable="false"/></column>
            <column name="area" type="VARCHAR(200)"/>
            <column name="severity" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="evidence" type="TEXT"/>
            <column name="root_cause" type="TEXT"/>
            <column name="corrective_action_required" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="audit_findings" indexName="ix_af_audit"><column name="audit_id"/></createIndex>
    </changeSet>

    <changeSet id="v014-003-audit-capa-link" author="eqms">
        <createTable tableName="audit_capa_link">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_audit_capa_link" nullable="false"/>
            </column>
            <column name="audit_finding_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_acl_finding" references="audit_findings(id)"/>
            </column>
            <column name="capa_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_acl_capa" references="capas(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <addUniqueConstraint tableName="audit_capa_link"
                             columnNames="audit_finding_id, capa_id" constraintName="uq_audit_finding_capa"/>
    </changeSet>

    <changeSet id="v014-004-audit-follow-up" author="eqms">
        <createTable tableName="audit_follow_up">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_audit_follow_up" nullable="false"/>
            </column>
            <column name="current_audit_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_afu_current" references="audits(id)"/>
            </column>
            <column name="previous_audit_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_afu_previous" references="audits(id)"/>
            </column>
            <column name="finding_id" type="BIGINT"/>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="audit_follow_up" indexName="ix_afu_current"><column name="current_audit_id"/></createIndex>
    </changeSet>

    <changeSet id="v014-005-audit-permissions" author="eqms">
        <sql dbms="postgresql"><![CDATA[
            INSERT INTO permissions (code, description, version, created_at, updated_at) VALUES
              ('AUDIT_MANAGE',  'Plan and conduct quality audits',     0, now(), now()),
              ('AUDIT_APPROVE', 'Sign off / finalize quality audits',  0, now(), now());

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code IN ('AUDIT_MANAGE','AUDIT_APPROVE')
            WHERE r.name = 'ADMIN';

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code IN ('AUDIT_MANAGE','AUDIT_APPROVE')
            WHERE r.name = 'QA_MANAGER';

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code = 'AUDIT_MANAGE'
            WHERE r.name = 'AUTHOR';
        ]]></sql>
        <rollback>
            <sql dbms="postgresql">
                DELETE FROM role_permissions WHERE permission_id IN
                    (SELECT id FROM permissions WHERE code IN ('AUDIT_MANAGE','AUDIT_APPROVE'));
                DELETE FROM permissions WHERE code IN ('AUDIT_MANAGE','AUDIT_APPROVE');
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
