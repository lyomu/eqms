<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Risk Management module (Milestone 13, ISO 31000 / ICH Q9). 4 tables + RISK permissions. -->

    <changeSet id="v015-001-risks" author="eqms">
        <createTable tableName="risks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_risks" nullable="false"/>
            </column>
            <column name="risk_no" type="VARCHAR(40)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_risks_no"/>
            </column>
            <column name="title" type="VARCHAR(400)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="category" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="potential_impact" type="TEXT"/>
            <column name="likelihood" type="INT"/>
            <column name="risk_score" type="INT"/>
            <column name="status" type="VARCHAR(40)"><constraints nullable="false"/></column>
            <column name="owner_id" type="BIGINT"/>
            <column name="submitted_by" type="BIGINT"/>
            <column name="accepted_by" type="BIGINT"/>
            <column name="accepted_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="closed_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="version" type="INT" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_by" type="BIGINT"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <createIndex tableName="risks" indexName="ix_risks_status"><column name="status"/></createIndex>
        <createIndex tableName="risks" indexName="ix_risks_category"><column name="category"/></createIndex>
    </changeSet>

    <changeSet id="v015-002-risk-analysis" author="eqms">
        <createTable tableName="risk_analysis">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_risk_analysis" nullable="false"/>
            </column>
            <column name="risk_id" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_risk_analysis"
                             foreignKeyName="fk_ra_risk" references="risks(id)"/>
            </column>
            <column name="analysis_method" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="findings" type="TEXT"/>
            <column name="consequence" type="TEXT"/>
            <column name="severity" type="INT"><constraints nullable="false"/></column>
            <column name="probability" type="INT"><constraints nullable="false"/></column>
            <column name="residual_risk_score" type="INT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="v015-003-risk-mitigation" author="eqms">
        <createTable tableName="risk_mitigation">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_risk_mitigation" nullable="false"/>
            </column>
            <column name="risk_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_rm_risk" references="risks(id)"/>
            </column>
            <column name="control_description" type="TEXT"><constraints nullable="false"/></column>
            <column name="control_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="owner_id" type="BIGINT"/>
            <column name="implementation_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="verification_method" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="risk_mitigation" indexName="ix_rm_risk"><column name="risk_id"/></createIndex>
    </changeSet>

    <changeSet id="v015-004-risk-control-effectiveness" author="eqms">
        <createTable tableName="risk_control_effectiveness">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_risk_control_effectiveness" nullable="false"/>
            </column>
            <column name="risk_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_rce_risk" references="risks(id)"/>
            </column>
            <column name="verification_date" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="verified_by" type="BIGINT"/>
            <column name="residual_risk_acceptable" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="evidence" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="risk_control_effectiveness" indexName="ix_rce_risk"><column name="risk_id"/></createIndex>
    </changeSet>

    <changeSet id="v015-005-risk-permissions" author="eqms">
        <sql dbms="postgresql"><![CDATA[
            INSERT INTO permissions (code, description, version, created_at, updated_at) VALUES
              ('RISK_CREATE',  'Identify, analyze and mitigate risks',  0, now(), now()),
              ('RISK_APPROVE', 'Accept and close risks (management)',   0, now(), now());

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code IN ('RISK_CREATE','RISK_APPROVE')
            WHERE r.name = 'ADMIN';

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code = 'RISK_APPROVE'
            WHERE r.name = 'QA_MANAGER';

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code = 'RISK_CREATE'
            WHERE r.name = 'AUTHOR';
        ]]></sql>
        <rollback>
            <sql dbms="postgresql">
                DELETE FROM role_permissions WHERE permission_id IN
                    (SELECT id FROM permissions WHERE code IN ('RISK_CREATE','RISK_APPROVE'));
                DELETE FROM permissions WHERE code IN ('RISK_CREATE','RISK_APPROVE');
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
