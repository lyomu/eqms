<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Training Management module (Milestone 15). 4 tables + TRAINING_MANAGE permission. -->

    <changeSet id="v017-001-training-programs" author="eqms">
        <createTable tableName="training_programs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_training_programs" nullable="false"/>
            </column>
            <column name="training_code" type="VARCHAR(40)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_training_code"/>
            </column>
            <column name="title" type="VARCHAR(400)"><constraints nullable="false"/></column>
            <column name="content" type="TEXT"/>
            <column name="intended_audience" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="required_frequency" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="version" type="INT" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_by" type="BIGINT"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <createIndex tableName="training_programs" indexName="ix_tp_audience"><column name="intended_audience"/></createIndex>
    </changeSet>

    <changeSet id="v017-002-training-assignments" author="eqms">
        <createTable tableName="training_assignments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_training_assignments" nullable="false"/>
            </column>
            <column name="training_program_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ta_program" references="training_programs(id)"/>
            </column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="assigned_date" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="due_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="completion_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="completion_evidence" type="VARCHAR(1000)"/>
            <column name="version" type="INT" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_by" type="BIGINT"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <addUniqueConstraint tableName="training_assignments"
                             columnNames="training_program_id, user_id" constraintName="uq_training_assignment"/>
        <createIndex tableName="training_assignments" indexName="ix_ta_status"><column name="status"/></createIndex>
        <createIndex tableName="training_assignments" indexName="ix_ta_user"><column name="user_id"/></createIndex>
    </changeSet>

    <changeSet id="v017-003-training-auto-rules" author="eqms">
        <createTable tableName="training_auto_rules">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_training_auto_rules" nullable="false"/>
            </column>
            <column name="training_program_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tar_program" references="training_programs(id)"/>
            </column>
            <column name="trigger_event" type="VARCHAR(120)"><constraints nullable="false"/></column>
            <column name="target_audience" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="due_within_days" type="INT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="training_auto_rules" indexName="ix_tar_program"><column name="training_program_id"/></createIndex>
    </changeSet>

    <changeSet id="v017-004-training-completion-audit" author="eqms">
        <createTable tableName="training_completion_audit">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_training_completion_audit" nullable="false"/>
            </column>
            <column name="training_assignment_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tca_assignment" references="training_assignments(id)"/>
            </column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="completion_date" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="completed_by" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="evidence_file" type="VARCHAR(1000)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="created_by" type="BIGINT"/>
        </createTable>
        <createIndex tableName="training_completion_audit" indexName="ix_tca_assignment">
            <column name="training_assignment_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="v017-005-training-permissions" author="eqms">
        <sql dbms="postgresql"><![CDATA[
            INSERT INTO permissions (code, description, version, created_at, updated_at) VALUES
              ('TRAINING_MANAGE', 'Create training programs and assign/manage training', 0, now(), now());

            INSERT INTO role_permissions (role_id, permission_id, version, created_at, updated_at)
            SELECT r.id, p.id, 0, now(), now()
            FROM roles r JOIN permissions p ON p.code = 'TRAINING_MANAGE'
            WHERE r.name IN ('ADMIN','QA_MANAGER');
        ]]></sql>
        <rollback>
            <sql dbms="postgresql">
                DELETE FROM role_permissions WHERE permission_id IN
                    (SELECT id FROM permissions WHERE code = 'TRAINING_MANAGE');
                DELETE FROM permissions WHERE code = 'TRAINING_MANAGE';
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
