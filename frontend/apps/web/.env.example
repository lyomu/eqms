# --- Frontend (apps/web) environment ---

# Base URL axios prepends to API calls. Leave EMPTY to use same-origin requests
# routed through the Next.js rewrite proxy (recommended for local dev — keeps the
# session cookie first-party and avoids CORS). Only set this to the backend origin
# directly if you have configured CORS on the backend.
NEXT_PUBLIC_API_BASE_URL=

# Backend origin that the Next.js rewrite proxy forwards /api/* to (server-side only).
BACKEND_ORIGIN=http://localhost:8080
